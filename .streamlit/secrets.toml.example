# 複製此檔為 secrets.toml（本地測試用）
# Streamlit Cloud 請直接在網站介面貼入以下內容

[google_oauth]

# 將你的 OAuth 用戶端金鑰 JSON 整個貼在這（Web 應用程式類型）
# 注意：要用單行字串，外面用單引號包住
client_secrets_json = '{"web":{"client_id":"你的client_id","project_id":"你的project_id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","client_secret":"你的client_secret","redirect_uris":["https://你的app網址.streamlit.app"]}}'

# Streamlit Cloud app 的完整網址（用於 OAuth redirect）
redirect_uri = "https://你的app網址.streamlit.app"
